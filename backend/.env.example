# 百炼 DashScope API
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
RERANK_MODEL=gte-rerank

# 数据库
DATABASE_URL=sqlite:///./data/app.db

# 文件上传
UPLOAD_DIR=./uploads

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# 服务端口（Agent 自动验证）
API_PORT=8099
